rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    // Role é lido do doc /users/{uid}.role. A vulnerabilidade de
    // auto-promoção é bloqueada pelas regras do match /users/{userId} abaixo
    // (usuário não consegue editar o próprio campo `role`).
    //
    // Optamos por NÃO usar custom claims via Cloud Function porque exige
    // plano Blaze; a leitura adicional do Firestore por operação é
    // desprezível no volume atual.
    function isAuth() {
      return request.auth != null;
    }

    function userRole() {
      return isAuth()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isFinanceiroOrAbove() {
      return userRole() in ['admin', 'financeiro'];
    }

    function isAnyStaff() {
      return userRole() in ['admin', 'operador', 'financeiro'];
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    // Restrict reads to own profile or admin — prevents cross-user reads of
    // sensitive fields like externalApiKey and webhookUrl.
    //
    // Writes:
    //  - Admins can write any field.
    //  - The user themselves can update their own profile, but cannot
    //    elevate privileges (role) or grant themselves new FSA access
    //    (allowedFsaIds). These are locked to the prior value.
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();

      allow create: if isAdmin() ||
        (request.auth.uid == userId &&
         (!('role' in request.resource.data) ||
           request.resource.data.role == 'visualizador') &&
         !('allowedFsaIds' in request.resource.data));

      allow update: if isAdmin() ||
        (request.auth.uid == userId &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.allowedFsaIds == resource.data.allowedFsaIds);

      allow delete: if isAdmin();
    }

    // ── Técnicos ──────────────────────────────────────────────────────────────
    match /technicians/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Clientes e Catálogo de Serviços ──────────────────────────────────────
    // Somente admin cria/edita clientes e serviços do catálogo.
    match /clientes/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /catalogoServicos/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── Chamados ──────────────────────────────────────────────────────────────
    // Qualquer usuário da equipe pode ler chamados.
    // Criação/edição: operador, admin.
    // Transições de status (validação/rejeição): operador ou financeiro, conforme etapa.
    match /chamados/{docId} {
      allow read:   if isAuth();
      allow create: if isAnyStaff();
      allow update: if isAnyStaff();
      allow delete: if isAdmin();
    }

    // ── Pagamentos ────────────────────────────────────────────────────────────
    match /pagamentos/{docId} {
      allow read:   if isAuth();
      allow create: if isFinanceiroOrAbove();
      allow update: if isFinanceiroOrAbove();
      allow delete: if isAdmin();
    }

    // ── Estoque ───────────────────────────────────────────────────────────────
    match /estoqueItens/{docId} {
      allow read:   if isAuth();
      allow write:  if isAnyStaff();
    }

    match /movimentosEstoque/{docId} {
      allow read:   if isAuth();
      allow create: if isAnyStaff();
      allow update, delete: if isAdmin();
    }

    // ── FSAs e Atribuições ────────────────────────────────────────────────────
    match /fsas/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /assignments/{docId} {
      allow read:           if isAuth();
      allow create, update: if isAnyStaff();
      allow delete:         if isAdmin();
    }

    match /activity/{docId} {
      allow read:           if isAuth();
      allow create:         if isAuth();
      allow update, delete: if isAdmin();
    }

    // ── Per-user data (RAT history & templates) ───────────────────────────────
    match /serviceReports/{docId} {
      allow read, delete, update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create:               if isAuth() && request.resource.data.userId == request.auth.uid;
      // Admin override
      allow read, write: if isAdmin();
    }

    match /ratTemplates/{docId} {
      allow read, delete, update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create:               if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // ── Shared team collections ───────────────────────────────────────────────
    match /schedulingNotes/{docId} {
      allow read:          if isAuth();
      allow create, update: if isAnyStaff();
      allow delete:         if isAdmin();
    }

    match /sharedData/{docId} {
      allow read:  if isAuth();
      allow write: if isAnyStaff();
    }

    match /knowledgeBase/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /diarioBordo/{docId} {
      allow read:   if isAuth();
      // Creator or admin can delete; no freeform edits after creation.
      allow create: if isAuth() && request.resource.data.criadoPor == request.auth.uid;
      allow delete: if resource.data.criadoPor == request.auth.uid || isAdmin();
      allow update: if isAdmin();
    }
  }
}
